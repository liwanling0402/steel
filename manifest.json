{
  "id": "com.steel.production",
  "name": "Steel钢材管理",
  "version": {
    "name": "4.0.0",
    "code": "400"
  },
  "description": "钢材加工生产财务管理系统 — 工业级APP",
  "icons": {
    "72": "unpackage/res/icons/72x72.png",
    "96": "unpackage/res/icons/96x96.png",
    "120": "unpackage/res/icons/120x120.png",
    "144": "unpackage/res/icons/144x144.png",
    "192": "unpackage/res/icons/192x192.png"
  },
  "launch_path": "index.html",
  "developer": {
    "name": "Steel Production Team"
  },
  "permissions": {
    "Android": {}
  },
  "plus": {
    "splashscreen": {
      "autoclose": true,
      "waiting": false,
      "delay": 0
    },
    "statusbar": {
      "immersed": true
    },
    "popGesture": "none",
    "runmode": "normal",
    "distribute": {
      "android": {
        "packagename": "com.steel.production",
        "permissions": [],
        "minSdkVersion": "21",
        "targetSdkVersion": "34",
        "abiFilters": ["armeabi-v7a", "arm64-v8a"]
      },
      "icons": {
        "android": {
          "hdpi": "unpackage/res/icons/72x72.png",
          "xhdpi": "unpackage/res/icons/96x96.png",
          "xxhdpi": "unpackage/res/icons/144x144.png"
        }
      }
    },
    "useragent": {
      "concatenate": false,
      "value": "Mozilla/5.0 (Linux; Android 13; Mobile) AppleWebKit/537.36"
    },
    "cache": {
      "mode": "force"
    },
    "kernel": {
      "ios": "WKWebview",
      "android": "X5Webview"
    },
    "webView": {
      "minUserAgent": false,
      "titleNView": false,
      "pullToRefresh": {
        "support": false
      },
      "scrollIndicator": "none",
      "bounce": "none",
      "overscrollEnabled": false,
      "render": "always",
      "popGesture": "none",
      "softinputNavBar": "auto",
      "backButtonAutoControl": "none",
      "hardwareAccelerated": true,
      "animationEngine": "canvas2d"
    },
    "allowsInlineMediaPlayback": true,
    "mediaPlaybackRequiresUserAction": false,
    "launchwebview": {
      "id": "main",
      "kernel": "X5Webview",
      "statusbar": {
        "background": "#1a2332"
      },
      "titleNView": false,
      "pullToRefresh": {
        "support": false
      },
      "scrollIndicator": "none",
      "bounce": "none",
      "popGesture": "none",
      "hardwareAccelerated": true,
      "overscrollEnabled": false
    },
    "secondwebview": {
      "id": "second",
      "launch_path": "__uniappview.html",
      "kernel": "X5Webview"
    },
    "nativePlugins": {},
    "modules": {}
  },
  "uni-app": {
    "compilerVersion": "4.0",
    "nvueCompiler": "weex",
    "renderer": "native"
  },
  "app-plus": {
    "compatible": {
      "ignoreVersion": true,
      "runtimeVersion": ""
    },
    "usingComponents": true,
    "nvueStyleCompiler": "weex",
    "compilerVersion": 4,
    "splashscreen": {
      "alwaysShowBeforeRender": true,
      "waiting": true,
      "autoclose": true,
      "delay": 0
    },
    "modules": {},
    "distribute": {
      "android": {
        "permissions": [
          "<uses-permission android:name=\"android.permission.INTERNET\"/>",
          "<uses-permission android:name=\"android.permission.ACCESS_NETWORK_STATE\"/>",
          "<uses-feature android:name=\"android.hardware.touchscreen\" android:required=\"true\"/>"
        ],
        "minSdkVersion": "21",
        "targetSdkVersion": "34",
        "abiFilters": ["armeabi-v7a", "arm64-v8a"]
      },
      "sdkConfigs": {},
      "icons": {
        "android": {
          "hdpi": "unpackage/res/icons/72x72.png",
          "xhdpi": "unpackage/res/icons/96x96.png",
          "xxhdpi": "unpackage/res/icons/144x144.png"
        }
      },
      "splashscreen": {
        "android": {
          "hdpi": "",
          "xhdpi": "",
          "xxhdpi": ""
        }
      }
    }
  },
  "h5": {
    "title": "Steel钢材管理系统",
    "router": {
      "mode": "hash"
    },
    "async": {
      "timeout": 3000,
      "loading": "数据加载中..."
    }
  },
  "networkTimeout": {
    "request": 10000,
    "connectSocket": 10000,
    "uploadFile": 10000,
    "downloadFile": 10000
  },
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "Steel钢材管理",
    "navigationBarBackgroundColor": "#1a2332",
    "backgroundColor": "#f0f2f5",
    "app-plus": {
      "titleNView": false,
      "popGesture": "none",
      "bounce": "none",
      "scrollIndicator": "none",
      "background": "#f0f2f5",
      "animationType": "pop-in",
      "animationDuration": 200
    }
  }
}
